# App
NODE_ENV=production
PORT=4000
API_PREFIX=api
CORS_ORIGINS=https://YOUR_ADMIN_DOMAIN,https://YOUR_CLIENT_DOMAIN

# Database (PostgreSQL — Beget Cloud)
DB_HOST=cebinretefal.beget.app
DB_PORT=5432
DB_USERNAME=CHANGE_ME_USER
DB_PASSWORD=CHANGE_ME_PASSWORD
DB_DATABASE=CHANGE_ME_DATABASE

# Redis (local Docker on server)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT (generate strong random secrets, min 64 chars)
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_STRONG_SECRET_64_CHARS_MIN
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# S3 (Beget Cloud)
S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS
S3_SECRET_KEY=CHANGE_ME_S3_SECRET
S3_BUCKET=CHANGE_ME_BUCKET
S3_REGION=ru1
S3_PUBLIC_URL=https://s3.ru1.storage.beget.cloud/CHANGE_ME_BUCKET
S3_CDN_URL=https://YOUR_CDN_DOMAIN

# Cookie domain (for cross-subdomain auth between api/admin/client)
COOKIE_DOMAIN=.yourdomain.com

# Email
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your-email@mail.ru
SMTP_PASS=your-app-password
MAIL_FROM='"SVOYA ESTHETICA" <noreply@yourdomain.com>'

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100
